@using FinanceManager.Application.Accounts.Shared
@using FinanceManager.Application.Shared.Extensions

<div class="list-group-item bg-transparent border-secondary d-flex justify-content-between align-items-center py-3">
    <div>
        <div class="fw-bold text-light">@Account.Name</div>
                
        <small class="text-muted">@Account.Type.GetDisplayName()</small>
    </div>
        
    <div class="text-end">
        <span class="fw-bold @BalanceStyles">@Account.Balance.ToString("C")</span>
    </div>
</div>

@code {
    [Parameter]
    public required AccountResponse Account { get; set; }

    private string BalanceStyles => Account.Balance >= 0 ? "text-success" : "text-danger";
}