@using System.Linq.Expressions
@using FinanceManager.Web.Shared.Types

<FormField Label="@Label" LabelAdditionalClasses="@LabelAdditionalClasses" ValueExpression="ValueExpression">
    <InputText
        Type="@Type"
        Value="@Value"
        ValueChanged="@ValueChanged"
        ValueExpression="@ValueExpression"
        class="form-field form-control form-control-lg mb-1"
        placeholder="@Placeholder" />
</FormField>

@code {
    [Parameter]
    public FormFieldType Type { get; set; } = FormFieldType.Text;
    [Parameter]
    public string? Label { get; set; }
    [Parameter]
    public string? LabelAdditionalClasses { get; set; } = "form-field-label";
    [Parameter]
    public string? Placeholder { get; set; }
    [Parameter]
    public string? Value { get; set; }
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }
    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }
}